<?xml version="1.0" encoding="UTF-8"?> 
<proxool-config>
	<proxool>
		<alias>gcld</alias>
		<driver-class>com.mysql.jdbc.Driver</driver-class>
		<driver-properties>
			<property name="user" value="root" />
			<property name="password" value="Asdhzlyd#@!@" />
		</driver-properties>
		<!-- proxool自动侦察各个连接状态的时间间隔(毫秒),侦察到空闲的连接就马上回收,超时的销毁 默认120秒 -->
		<house-keeping-sleep-time>120000</house-keeping-sleep-time>
		 <!--最少保持的空闲连接数(默认20个)-->
		<prototype-count>10</prototype-count>
		<!-- 是指在任一时刻，可以（同时）建立的最大连接数，也就是说，就是已经请求的、但还没可用的新连接数量-->
		<simultaneous-build-throttle>20</simultaneous-build-throttle>
		<!--最大连接数(默认1000个),超过了这个连接数,再有请求时,就排在队列中等候,最大的等待请求数由maximum-new-connections决定 -->
		<maximum-connection-count>1000</maximum-connection-count>
		<!--最小连接数(默认20个)-->
		<minimum-connection-count>20</minimum-connection-count>
		 <!--没有空闲连接可以分配而在队列中等候的最大请求数,超过这个请求数的用户连接就不会被接受-->
        <simultaneous-build-throttle>950</simultaneous-build-throttle>
		<!--如果housekeeper 检测到某个连接 的活动时间大于这个数值(毫秒).它将会杀掉这个连接 -->
		<maximum-active-time>600000</maximum-active-time>
		<!--在使用之前测试-->
		<test-before-use>true</test-before-use>
		<!--用于保持连接的测试语句 -->
		<house-keeping-test-sql>select 1</house-keeping-test-sql>
	</proxool>
</proxool-config> 
